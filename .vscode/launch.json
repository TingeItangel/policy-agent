{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Package",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceRoot}",
      "buildFlags": "-buildvcs=false"
    },
    {
      "name": "Attach to Policy Agent (remote pod)",
      "type": "go",
      "request": "attach",
      "mode": "remote",
      "host": "127.0.0.1",
      "port": 40000,
      "remotePath": "/app",
      "substitutePath": [
        { "from": "/app", "to": "C:\\Users\\claud\\Documents\\policy-agent" },
        { "from": "C:\\Users\\claud\\Documents\\policy-agent", "to": "/app" }
      ],
      "showLog": true,
      "trace": "verbose"
    }
  ]
}
